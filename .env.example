# ============================================
# 职场价值评估系统 - 环境配置文件
# ============================================
# 使用方法：
# 1. 复制本文件为 .env
# 2. 填入你的配置值
# ============================================

# ============================================
# AWS Bedrock - Sonnet 模型（备用）
# ============================================
# 在 AWS 控制台开通 Bedrock Claude 模型访问权限后获取
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# SONNET_MODEL_ID=anthropic.claude-sonnet-4-20250514

# ============================================
# 智谱 GLM（主力模型，必填）
# ============================================
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key
GLM_MODEL=glm-4.5
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# 用户用量预算
# ============================================
# 每用户 Sonnet 预算上限（人民币）
# SONNET_BUDGET_PER_USER=15
# Sonnet 价格配置（人民币/千token，一般无需修改）
# SONNET_INPUT_PRICE_PER_1K=0.022
# SONNET_OUTPUT_PRICE_PER_1K=0.11

# ============================================
# 基础设施
# ============================================
# API 服务端口（可选，默认 5000）
# API_PORT=5000

# Tavily Search API（用于全网岗位搜索，免费1000次/月）
# 获取地址：https://app.tavily.com
# TAVILY_API_KEY=tvly-your_api_key_here
