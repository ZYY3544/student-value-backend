# ============================================
# 职场价值评估系统 - 环境配置文件
# ============================================
# 使用方法：
# 1. 复制本文件为 .env
# 2. 填入你的配置值
# ============================================

# DeepSeek API Key（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here

# DeepSeek 模型（可选，默认 deepseek-chat）
# 可选值：deepseek-chat（快速）、deepseek-reasoner（深度推理）
# DEEPSEEK_MODEL=deepseek-chat

# API 服务端口（可选，默认 5000）
# API_PORT=5000

# Bing Search API（可选，不配置则降级为 DuckDuckGo）
# 获取地址：https://portal.azure.com/ → Bing Search v7
# BING_SEARCH_API_KEY=your_bing_api_key_here
